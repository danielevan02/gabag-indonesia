generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  discount        Int?      @default(0)
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  image           String?
  isEventCategory Boolean   @default(false)
  products        Product[] @relation("CategoryToProduct")
}

model Product {
  id                       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  slug                     String      @unique(map: "product_slug_idx")
  description              String
  images                   String[]
  stock                    Int         @default(0)
  price                    BigInt      @default(0)
  rating                   Int         @default(0)
  discount                 Int         @default(0)
  numReviews               Int         @default(0)
  isFeatured               Boolean     @default(false)
  banner                   String?
  hasVariant               Boolean     @default(false)
  createdAt                DateTime    @default(now()) @db.Timestamp(6)
  hasDifferentVariantPrice Boolean     @default(false)
  height                   Decimal     @default(0) @db.Decimal(12, 2)
  length                   Decimal     @default(0) @db.Decimal(12, 2)
  sku                      String?
  weight                   Decimal     @default(0) @db.Decimal(12, 2)
  width                    Decimal     @default(0) @db.Decimal(12, 2)
  orderItem                OrderItem[]
  variant                  Variant[]
  categories               Category[]  @relation("CategoryToProduct")
}

model Variant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  name      String
  discount  Int?     @default(0)
  stock     Int      @default(0)
  price     BigInt   @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  image     String   @default("")
  sku       String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItem OrderItem[]
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @default("NO_NAME")
  email         String    @unique(map: "user_email_idx")
  emailVerified DateTime? @db.Timestamp(6)
  image         String?
  password      String?
  role          String    @default("user")
  address       Json?     @db.Json
  paymentMethod String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt
  phone         String    @unique @default("")
  accounts      Account[]
  cart          Cart[]
  order         Order[]
  sessions      Session[]
}

model Account {
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Cart {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @db.Uuid
  sessionCartId String
  items         Json[]   @default([]) @db.Json
  itemsPrice    BigInt   @default(0)
  totalPrice    BigInt   @default(0)
  taxPrice      BigInt   @default(0)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  weight        Decimal  @default(0) @db.Decimal(12, 2)
  shippingPrice BigInt?  @default(0)
  notes         String?
  orderId       String?  @unique @default(uuid())
  order         Order?   @relation(fields: [orderId], references: [id])
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id               String      @id
  userId           String      @db.Uuid
  itemsPrice       BigInt      @default(0)
  totalPrice       BigInt      @default(0)
  shippingPrice    BigInt      @default(0)
  taxPrice         BigInt      @default(0)
  isPaid           Boolean     @default(false)
  isDelivered      Boolean     @default(false)
  deliveredAt      DateTime?   @db.Timestamp(6)
  paidAt           DateTime?   @db.Timestamp(6)
  createdAt        DateTime    @default(now()) @db.Timestamp(6)
  transactionToken String?     @unique @default("")
  courier          String?     @default("")
  notes            String?     @default("")
  paymentStatus    String?     @default("")
  shippingInfo     Json?       @db.Json
  cart             Cart?
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
}

model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @default(uuid())
  productId String  @db.Uuid
  qty       Int
  price     BigInt  @default(0)
  name      String
  slug      String
  image     String
  variantId String? @db.Uuid
  weight    Decimal @default(0) @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId, variantId], map: "orderitems_orderId_productId_variantId_unique")
}